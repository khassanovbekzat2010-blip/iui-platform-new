DATABASE_URL="file:./dev.db"
# Vercel / production:
# POSTGRES_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Auth / Session
AUTH_SESSION_SECRET="replace-with-long-random-secret-min-32-chars"
AUTH_OTP_SECRET="replace-with-long-random-secret-min-32-chars"

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
DEV_OTP_FALLBACK="true"

# S3-compatible storage metadata for lesson archive
S3_BUCKET=""
S3_REGION=""
S3_PUBLIC_BASE_URL=""

# Optional AI control:
# AI_PROVIDER="disabled"  # disables AI processing and always returns fallback

# OpenAI personalization
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# EEG / ESP32
# For local/dev pairing teacher can bind ESP32 by deviceId only.
# Set this to "false" to require Bearer device token again in production.
IUI_ALLOW_EEG_WITHOUT_TOKEN="true"
IUI_EEG_ALLOWED_ORIGINS="*"

# Vercel deploy notes:
# 1. Keep local dev on sqlite via prisma/schema.prisma
# 2. Vercel uses prisma/schema.postgres.prisma through `npm run vercel-build`
# 3. Create a managed Postgres database first (Neon / Supabase / Railway)
# 4. Put that URL into `POSTGRES_DATABASE_URL`
